#!/usr/bin/env bash
# =============================================================================
# Aigent — runtime launcher / multiplexor (Unix / Git-Bash)
#
# Punto de entrada ÚNICO para todo runtime de Node: node, npm y npx. Lo usan
# TODAS las invocaciones de skills y del engine v2 en lugar de llamar a
# `node`/`npm`/`npx` a secas (que NO están garantizados en el PATH del IDE).
#
# Uso:
#   .aigent/IDE/bin/run [node|npm|npx] <args...>
#
#   · Si el 1er argumento es exactamente `node`, `npm` o `npx`, ese es el runtime
#     y el resto de argumentos se le reenvían tal cual.
#   · Si NO lo es (p. ej. un script .cjs), se asume `node` (retrocompatibilidad
#     con el contrato anterior `run <script.cjs> [args...]`).
#
# Resolución (igual para los tres runtimes) — SYSTEM-FIRST:
#   1) El del sistema en PATH, si existe y cumple requisitos (Node >= 20).
#   2) Si no, el bundled que el instalador descargó en .aigent/IDE/bin/deps/
#      (node[.exe] + node_modules/npm/bin/{npm,npx}-cli.js, del propio tarball).
#   3) Si nada sirve, error TIPADO (JSON a stdout + línea [ERROR ...] a stderr).
#
# Contrato de errores (idéntico en run y run.cmd, para que el caller/IA lo parsee):
#   stdout: {"ok":false,"error":{"code":"<CODE>","runtime":"<rt>","message":"..."}}
#   stderr: [ERROR <CODE>] (<rt>) <message>
#   exit:   1
#   Códigos: RUNTIME_UNAVAILABLE  (el runtime pedido no existe ni en sistema ni bundled)
#
# Nota: cuando el runtime SÍ resuelve, el launcher hace `exec` y NO envuelve la
# salida ni el exit code del programa — el error tipado es solo del propio launcher.
# =============================================================================
set -euo pipefail

MIN_MAJOR=20

# Carpeta del propio launcher (para encontrar el bundle hermano en deps/).
SELF="${BASH_SOURCE[0]}"
DIR="$(cd "$(dirname "$SELF")" && pwd)"
DEPS="$DIR/deps"

# Emite el error tipado del launcher y sale con 1.  $1=code $2=runtime $3=message
emit_error() {
  printf '{"ok":false,"error":{"code":"%s","runtime":"%s","message":"%s"}}\n' "$1" "$2" "$3"
  printf '[ERROR %s] (%s) %s\n' "$1" "$2" "$3" >&2
  exit 1
}

# ¿Es `$1` un Node ejecutable que cumple el suelo de versión?
node_usable() {
  local bin="$1" v major
  v="$("$bin" -v 2>/dev/null)" || return 1   # p.ej. "v24.14.1"
  v="${v#v}"; major="${v%%.*}"
  case "$major" in ''|*[!0-9]*) return 1 ;; esac
  [ "$major" -ge "$MIN_MAJOR" ]
}

# Node bundled usable (node en Unix/mac, node.exe en Git-Bash). Echo de la ruta.
bundled_node() {
  local c
  for c in "$DEPS/node" "$DEPS/node.exe"; do
    if [ -x "$c" ] && node_usable "$c"; then printf '%s' "$c"; return 0; fi
  done
  return 1
}

# Node del sistema usable (node.exe primero: en Git Bash `node` es un alias winpty
# que no funciona en scripts; el binario node.exe sí). Echo del comando/ruta.
system_node() {
  local s
  for s in node.exe node; do
    if command -v "$s" >/dev/null 2>&1 && node_usable "$s"; then printf '%s' "$s"; return 0; fi
  done
  return 1
}

# ── Selección de runtime (default node) ──────────────────────────────────────
RUNTIME="node"
case "${1:-}" in
  node) RUNTIME="node"; shift ;;
  npm)  RUNTIME="npm";  shift ;;
  npx)  RUNTIME="npx";  shift ;;
  *)    RUNTIME="node" ;;   # retrocompat: `run <script.cjs> ...`
esac

case "$RUNTIME" in
  node)
    if sys="$(system_node)"; then exec "$sys" "$@"; fi
    if bn="$(bundled_node)";  then exec "$bn"  "$@"; fi
    emit_error "RUNTIME_UNAVAILABLE" "node" \
      "No hay Node >= ${MIN_MAJOR} usable ni en el sistema (PATH) ni bundled (${DEPS}/node[.exe]). Reinstala el runtime con .aigent/IDE/install.sh (o install.ps1)."
    ;;
  npm)
    if command -v npm >/dev/null 2>&1; then exec npm "$@"; fi
    if bn="$(bundled_node)"; then
      cli="$DEPS/node_modules/npm/bin/npm-cli.js"
      [ -f "$cli" ] && exec "$bn" "$cli" "$@"
    fi
    emit_error "RUNTIME_UNAVAILABLE" "npm" \
      "No hay npm ni en el sistema (PATH) ni bundled (${DEPS}/node_modules/npm). Conserva npm en el runtime bundled (instalador) o instala npm en el sistema."
    ;;
  npx)
    if command -v npx >/dev/null 2>&1; then exec npx "$@"; fi
    if bn="$(bundled_node)"; then
      cli="$DEPS/node_modules/npm/bin/npx-cli.js"
      [ -f "$cli" ] && exec "$bn" "$cli" "$@"
    fi
    emit_error "RUNTIME_UNAVAILABLE" "npx" \
      "No hay npx ni en el sistema (PATH) ni bundled (${DEPS}/node_modules/npm). Conserva npm (incluye npx) en el runtime bundled o instala Node en el sistema."
    ;;
esac
