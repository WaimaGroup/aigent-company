{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "brave-search": {
      "type": "local",
      "command": ["npx", "-y", "@modelcontextprotocol/server-brave-search"],
      "environment": {
        "BRAVE_API_KEY": "your-brave-api-key-here"
      },
      "enabled": true
    }
  },
  "model": "anthropic/claude-sonnet-4-6",
  "permission": {
    "edit": "allow",
    "webfetch": "allow",
    "bash": {
      "node *": "allow",
      "npm *": "allow",
      "npx *": "allow",
      "yarn *": "allow",
      "pnpm *": "allow",
      "python *": "allow",
      "python3 *": "allow",
      "pip *": "allow",
      "pip3 *": "allow",
      "pipx *": "allow",
      "uv *": "allow",
      "poetry *": "allow",
      "powershell *": "allow",
      "pwsh *": "allow",
      "powershell.exe *": "allow",
      "pwsh.exe *": "allow",
      "Get-ChildItem *": "allow",
      "gci *": "allow",
      "Get-Content *": "allow",
      "gc *": "allow",
      "Get-Item *": "allow",
      "Get-ItemProperty *": "allow",
      "Get-Location*": "allow",
      "Set-Location *": "allow",
      "Test-Path *": "allow",
      "Resolve-Path *": "allow",
      "Split-Path *": "allow",
      "Join-Path *": "allow",
      "Select-String *": "allow",
      "Select-Object *": "allow",
      "Where-Object *": "allow",
      "Sort-Object *": "allow",
      "Measure-Object *": "allow",
      "Group-Object *": "allow",
      "ForEach-Object *": "allow",
      "Format-Table *": "allow",
      "Format-List *": "allow",
      "Out-String *": "allow",
      "Get-Command *": "allow",
      "Get-Date*": "allow",
      "New-Item *": "allow",
      "Copy-Item *": "allow",
      "Move-Item *": "allow",
      "Set-Content *": "allow",
      "Add-Content *": "allow",
      "Out-File *": "allow",
      "bash *": "allow",
      "sh *": "allow",
      "ls *": "allow",
      "dir *": "allow",
      "cd *": "allow",
      "pushd *": "allow",
      "popd *": "allow",
      "type *": "allow",
      "where *": "allow",
      "findstr *": "allow",
      "cat *": "allow",
      "head *": "allow",
      "tail *": "allow",
      "less *": "allow",
      "wc *": "allow",
      "find *": "allow",
      "grep *": "allow",
      "rg *": "allow",
      "tree *": "allow",
      "file *": "allow",
      "stat *": "allow",
      "mkdir *": "allow",
      "touch *": "allow",
      "cp *": "allow",
      "mv *": "allow",
      "echo *": "allow",
      "printf *": "allow",
      "sed *": "allow",
      "awk *": "allow",
      "tr *": "allow",
      "sort *": "allow",
      "uniq *": "allow",
      "cut *": "allow",
      "diff *": "allow",
      "tar *": "allow",
      "zip *": "allow",
      "unzip *": "allow",
      "curl *": "allow",
      "wget *": "allow",
      "git status*": "allow",
      "git diff*": "allow",
      "git log*": "allow",
      "git show*": "allow",
      "git branch*": "allow",
      "git remote*": "allow",
      "git fetch*": "allow",
      "git pull*": "allow",
      "git add*": "allow",
      "git commit*": "allow",
      "git stash*": "allow",
      "git switch*": "allow",
      "git checkout*": "allow",
      "git merge*": "allow",
      "git tag*": "allow",
      ".aigent/IDE/bin/run*": "allow",
      "./install.sh*": "allow",
      ".aigent/IDE/install.sh*": "allow",
      ".aigent/IDE/install.ps1*": "allow",
      "rm *": "ask",
      "rmdir *": "ask",
      "sudo *": "ask",
      "su *": "ask",
      "chmod *": "ask",
      "chown *": "ask",
      "Remove-Item *": "ask",
      "git push*": "ask",
      "git push --force*": "ask",
      "git push -f*": "ask",
      "git reset --hard*": "ask",
      "git clean -fd*": "ask",
      "git rebase*": "ask",
      "git filter-branch*": "ask",
      "npm publish*": "ask",
      "yarn publish*": "ask",
      "pnpm publish*": "ask",
      "npm install -g*": "ask",
      "pip uninstall*": "ask",
      "docker rm *": "ask",
      "docker rmi *": "ask",
      "docker system prune*": "ask",
      "docker volume rm*": "ask",
      "kubectl delete*": "ask",
      "terraform apply*": "ask",
      "terraform destroy*": "ask",
      "curl * | sh*": "ask",
      "curl * | bash*": "ask",
      "wget * | sh*": "ask",
      "wget * | bash*": "ask",
      "eval *": "ask",
      "crontab *": "ask",
      "rm -rf /*": "deny",
      "rm -rf ~*": "deny",
      "rm -rf $HOME*": "deny",
      "rm -rf .*": "deny",
      "rm -rf ./*": "deny",
      "rm -rf ..*": "deny",
      "dd *": "deny",
      "mkfs*": "deny",
      "format *": "deny",
      "shutdown*": "deny",
      "reboot*": "deny",
      "halt*": "deny",
      "poweroff*": "deny",
      "*": "ask"
    }
  }
}
